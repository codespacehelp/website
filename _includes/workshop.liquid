---
layout: default
---
<section class="workshop-page">
  <div class="workshop-page__header">
    <h1 class="text-H">{{ title }}</h1>
    <p class="text-h">Workshop — {{ workshop_date | date:"%Y-%m-%d" }} // Location: {{ room }} — {{ workshop_time }}</p>
  </div>
  {% render "tech-line.liquid" %}
</section>

<div class="page" style="background: var(--color-main);">
  {{ content }}
  {% unless done %}

  <h2>Reservation</h2>
  <p class="text-p">
    To ensure enough room for every student, we ask that you reserve your spot
    in the workshop by registering.<br />Email lieven.menschaert@kdg.be if you
    want to change your reservation.
  </p>
  <form name="workshops" method="POST" data-netlify="true">
    <div class="form__row">
      <label
        ><span class="form__label">Name</span
        ><input class="form__field" type="text" name="name" required
      /></label>
    </div>
    <div class="form__row">
      <label
        ><span class="form__label">KdG Email Address</span
        ><input class="form__field" type="email" name="email" required
      /></label>
    </div>
    <input type="hidden" name="workshop_title" value="{{ title }}" />
    <input type="hidden" name="workshop_date" value="{{ workshop_date | date:"%Y%m%d" }}" />
    <input type="hidden" name="workshop_time" value="{{ workshop_time }}" />
    <input type="hidden" name="workshop_room" value="{{ room }}" />

    <div class="form__row">
      <label
        ><span class="form__label">Remarks</span
        ><span class="form__help">E.g. special needs, ...</span
        ><textarea class="form__field" name="question"></textarea>
      </label>
    </div>
    <div class="form__row">
      <button class="form__button" type="submit">Make a reservation</button>
    </div>
  </form>
  {% endunless %}
</div>
