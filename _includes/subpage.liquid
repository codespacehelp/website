---
layout: default
---
<section class="subpage">
  <div class="subpage__header">
    {% if name %}
      <h1 class="text-H">{{ name }}</h1>
    {% else %}
      <h1 class="text-H">{{ title }}</h1>
    {% endif %}

    {% if workshop_date %}
      <p class="text-h">Workshop — {{ workshop_date | date:"%Y-%m-%d" }} // Location: {{ room }} — {{ workshop_time }}</p>
    {% elsif machine_model and machine_model != "" %}
      <p class="text-h">{{ machine_model }}</p>
    {% elsif student %}
      <p class="text-h">{{ student }} // {{ project_type }} // {{ project_year }}</p>
    {% elsif subtitle %}
      <p class="text-h">{{ subtitle }}</p>
    {% endif %}

    {% if student and summary %}
      <p class="text-p subpage__meta">{{ summary }}</p>
    {% endif %}
    {% if student and tech_stack %}
      <p class="text-p subpage__meta">Tools: {{ tech_stack }}</p>
    {% endif %}
  </div>
  {% render "tech-line.liquid" %}
</section>

<div class="page subpage__content">
  {% if image_path and image_path != "" %}
    <img class="subpage__hero" src="{{ image_path }}" alt="{{ name }}" loading="lazy" />
  {% endif %}
  {% if machine_model and description and description != "" %}
    <p>{{ description }}</p>
  {% endif %}
  {{ content }}
  {% if workshop_date %}
    {% unless done %}
      {% render "workshop-form.liquid", title: title, workshop_date: workshop_date, workshop_time: workshop_time, room: room %}
    {% endunless %}
  {% endif %}
</div>
