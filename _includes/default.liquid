---
layout: base
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="site-header__logo"><img src="/static/img/CSlogoWebWhite.png" alt="Code Space"></a>
    {% render "tab-nav.liquid", navigation: navigation, page: page %}
  </div>
</header>

<main class="card-nav__main-content" id="main-content">
  {{ content }}
</main>

<footer>
  <div class="inner grid">
    <div class="footer__logos">
      <img src="/static/img/logo_sintlucasantwerpen_wit.png" alt="Sint Lucas Antwerpen">
      <img src="/static/img/EN-KdG-wit-horizontaal.png" alt="Karel de Grote">
    </div>
    <p>
      Code Space is an initiative of <a href="https://www.sintlucasantwerpen.be/" target="_blank">Sint Lucas Antwerpen</a>.
    </p>
  </div>
</footer>

<script>
(function() {
  var nav = document.getElementById('card-nav');
  var main = document.getElementById('main-content');
  if (!nav || !main) return;

  var cards = Array.from(nav.querySelectorAll('.card-nav__card'));
  var activeCard = nav.querySelector('.card-nav__card--active');
  var activeLabel = activeCard ? activeCard.querySelector('.card-nav__tab-label') : null;
  var isOpen = false;
  var revealHeight = 100;
  var N = cards.length;

  function isMobile() {
    return window.matchMedia('(max-width: 768px)').matches;
  }

  function openMenu() {
    if (!isMobile()) return;
    isOpen = true;
    nav.classList.add('card-nav--open');
    if (activeLabel) activeLabel.setAttribute('aria-expanded', 'true');

    // Active card slides down the most (top of the stack)
    // Bottom card (first non-active) stays at offset 0
    var nonActiveIdx = 0;
    cards.forEach(function(card) {
      if (card.classList.contains('card-nav__card--active')) {
        var offset = (N - 1) * revealHeight;
        card.style.setProperty('--card-offset', offset + 'px');
        card.style.zIndex = N + 1;
      } else {
        var offset = nonActiveIdx * revealHeight;
        card.style.setProperty('--card-offset', offset + 'px');
        card.style.zIndex = nonActiveIdx + 1;
        nonActiveIdx++;
      }
    });
    main.style.marginTop = ((N - 1) * revealHeight) + 'px';
  }

  function closeMenu() {
    isOpen = false;
    nav.classList.remove('card-nav--open');
    if (activeLabel) activeLabel.setAttribute('aria-expanded', 'false');

    cards.forEach(function(card) {
      card.style.setProperty('--card-offset', '0px');
      card.style.zIndex = '';
    });
    main.style.marginTop = '0px';
  }

  if (activeLabel) {
    activeLabel.addEventListener('click', function(e) {
      e.preventDefault();
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });
  }

  cards.forEach(function(card) {
    if (card.classList.contains('card-nav__card--active')) return;

    card.addEventListener('click', function(e) {
      if (!isOpen || !isMobile()) return;
      e.preventDefault();
      var url = card.dataset.url;

      card.classList.add('card-nav__card--navigating');

      function navigate() {
        window.location.href = url;
      }

      card.addEventListener('transitionend', function handler() {
        card.removeEventListener('transitionend', handler);
        navigate();
      });

      setTimeout(navigate, 350);
    });
  });

  document.addEventListener('click', function(e) {
    if (isOpen && !nav.contains(e.target)) {
      closeMenu();
    }
  });

  window.matchMedia('(max-width: 768px)').addEventListener('change', function(e) {
    if (!e.matches && isOpen) {
      closeMenu();
    }
  });
})();
</script>
