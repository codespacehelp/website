---
layout: base
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="site-header__logo"><img src="/static/img/CSlogoWebWhite.png" alt="Code Space"></a>
    {% render "tab-nav.liquid", navigation: navigation, page: page %}
  </div>
</header>

<div class="mobilemenu" id="mobilemenu">
  {% for tab in navigation.tabs %}
    {% assign is_active = false %}
    {% if page.url == tab.url %}
      {% assign is_active = true %}
    {% elsif tab.url != "/" and page.url contains tab.url %}
      {% assign is_active = true %}
    {% endif %}
    {% if is_active %}
      <div class="mobilemenu__page mobilemenu__page--active"
           style="--card-index: {{ forloop.index0 }}; --card-total: {{ navigation.tabs.size }};">
        <button class="mobilemenu__tab mobilemenu__tab--active"
                aria-label="Toggle menu" aria-expanded="false">
          <span class="mobilemenu__icon material-symbols-outlined mobilemenu__icon-menu">menu</span>
          <span class="mobilemenu__icon material-symbols-outlined mobilemenu__icon-close">close</span>
          {{ tab.label }}
        </button>
        <main class="mobilemenu__body mobilemenu__body--active" id="main-content">
          {{ content }}
        </main>
      </div>
    {% else %}
      <div class="mobilemenu__page"
           data-url="{{ tab.url }}"
           style="--card-index: {{ forloop.index0 }}; --card-total: {{ navigation.tabs.size }};">
        <a href="{{ tab.url }}" class="mobilemenu__tab">
          {{ tab.label }}
        </a>
        <div class="mobilemenu__body"></div>
      </div>
    {% endif %}
  {% endfor %}
</div>

<footer>
  <div class="inner grid">
    <div class="footer__logos">
      <img src="/static/img/logo_sintlucasantwerpen_wit.png" alt="Sint Lucas Antwerpen">
      <img src="/static/img/EN-KdG-wit-horizontaal.png" alt="Karel de Grote">
    </div>
    <p>
      Code Space is an initiative of <a href="https://www.sintlucasantwerpen.be/" target="_blank">Sint Lucas Antwerpen</a>.
    </p>
  </div>
</footer>

<script>
(function() {
  var nav = document.getElementById('mobilemenu');
  if (!nav) return;

  var cards = Array.from(nav.querySelectorAll('.mobilemenu__page'));
  var activeCard = nav.querySelector('.mobilemenu__page--active');
  var activeLabel = activeCard ? activeCard.querySelector('.mobilemenu__tab') : null;
  var isOpen = false;
  var revealHeight = 55;
  var N = cards.length;

  function isMobile() {
    return window.matchMedia('(max-width: 768px)').matches;
  }

  function openMenu() {
    if (!isMobile()) return;
    isOpen = true;
    nav.classList.add('mobilemenu--open');
    if (activeLabel) activeLabel.setAttribute('aria-expanded', 'true');

    // Padding on container creates space for cascade; no margin-collapse issues
    nav.style.paddingTop = ((N - 1) * revealHeight) + 'px';

    var nonActiveIdx = 0;
    cards.forEach(function(card) {
      if (!card.classList.contains('mobilemenu__page--active')) {
        var offset = nonActiveIdx * revealHeight;
        card.style.setProperty('--card-offset', offset + 'px');
        card.style.zIndex = nonActiveIdx + 1;
        nonActiveIdx++;
      }
    });
  }

  function closeMenu() {
    isOpen = false;
    nav.classList.remove('mobilemenu--open');
    if (activeLabel) activeLabel.setAttribute('aria-expanded', 'false');

    nav.style.paddingTop = '0px';

    cards.forEach(function(card) {
      card.style.setProperty('--card-offset', '0px');
      card.style.zIndex = '';
    });
  }

  if (activeLabel) {
    activeLabel.addEventListener('click', function(e) {
      e.preventDefault();
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });
  }

  cards.forEach(function(card) {
    if (card.classList.contains('mobilemenu__page--active')) return;

    card.addEventListener('click', function(e) {
      if (!isOpen || !isMobile()) return;
      e.preventDefault();
      var url = card.dataset.url;

      card.classList.add('mobilemenu__page--navigating');

      function navigate() {
        window.location.href = url;
      }

      card.addEventListener('transitionend', function handler() {
        card.removeEventListener('transitionend', handler);
        navigate();
      });

      setTimeout(navigate, 350);
    });
  });

  document.addEventListener('click', function(e) {
    if (isOpen && !nav.contains(e.target)) {
      closeMenu();
    }
  });

  window.matchMedia('(max-width: 768px)').addEventListener('change', function(e) {
    if (!e.matches && isOpen) {
      closeMenu();
    }
  });
})();
</script>
