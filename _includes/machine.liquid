---
layout: default
---
<section class="machine-detail" style="background: var(--color-main);">
  <div class="inner">
    <h1 class="text-H">{{ name }}</h1>
    {% if machine_model and machine_model != "" %}
    <p class="text-s">{{ machine_model }}</p>
    {% endif %}
    {% if image_path and image_path != "" %}
    <img src="{{ image_path }}" alt="{{ name }}" loading="lazy" />
    {% endif %}
    <div class="text-p">
      {{ content }}
    </div>
  </div>
</section>
